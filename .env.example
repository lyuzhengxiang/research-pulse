# ===== Web (apps/web) =====
# Used by Next.js client + server. Copy to apps/web/.env.local
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# Server-only — used by the Generate Summary server action; never sent to the client.
# (No service role key needed: writes go through the set_paper_tldr_if_null RPC,
# a SECURITY DEFINER function granted only to authenticated users.)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== Worker (apps/worker) =====
# Copy to apps/worker/.env
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...            # service role key, keeps RLS bypass
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx  # classic PAT, public_repo scope

# Optional tuning
ARXIV_CATEGORIES=cs.AI,cs.LG,cs.CL,cs.CV,stat.ML
ACTIVE_WINDOW_DAYS=7
